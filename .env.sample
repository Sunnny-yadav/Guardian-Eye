# -------------------------------------------------------------------
# Environment Configuration Sample File
# -------------------------------------------------------------------

# MongoDB connection string
# Replace <username>, <password>, <cluster-url>, and <dbname> with your details
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<dbname>

# Node environment
# Options: development, production, test
NODE_ENV=development

# -------------------------------------------------------------------
# Authentication
# -------------------------------------------------------------------

# JWT secret key for authentication (replace with a strong secret)
JWT_SECRET=your_jwt_secret_here

# JWT token expiry time (optional)
JWT_EXPIRES_IN=1d

# -------------------------------------------------------------------
# External APIs
# -------------------------------------------------------------------

# OpenStreetMap (Nominatim) API for geolocation
NOMINATIM_URI=

# OpenWeather API key
OPEN_WEATHER_API_KEY=your_openweather_api_key_here

# -------------------------------------------------------------------
# Cloudinary Credentials
# -------------------------------------------------------------------

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# -------------------------------------------------------------------
# WebSocket Configuration
# -------------------------------------------------------------------

# URL of the Socket.IO server
NEXT_PUBLIC_SOCKET_SERVER_URL=http://localhost:4000

# -------------------------------------------------------------------
# ML Model Endpoints
# -------------------------------------------------------------------

INTENSITY_PREDICTION_URL=your_endpoint
RESOURCE_ESTIMATION_URL=your_endpoint
EVACUATION_MAP_URL=your_endpoint


# -------------------------------------------------------------------
# Notes:
# 1. Never commit real credentials to version control.
# 2. Copy this file as '.env' and replace placeholder values.
# 3. Add any other environment variables your project requires here.
# -------------------------------------------------------------------