# -------------------------------------------------------------------
# Environment Configuration Sample File
# -------------------------------------------------------------------

# MongoDB connection string
# Replace <username>, <password>, <cluster-url>, and <dbname> with your details
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<dbname>

# Node environment
# Options: development, production, test
NODE_ENV=development

# JWT secret key for authentication (replace with a strong secret)
JWT_SECRET=your_jwt_secret_here

# JWT token expiry time (optional)
JWT_EXPIRES_IN=1d



# -------------------------------------------------------------------
# Notes:
# 1. Never commit real credentials to version control.
# 2. Copy this file as '.env' and replace placeholder values.
# 3. Add any other environment variables your project requires here.
# -------------------------------------------------------------------
